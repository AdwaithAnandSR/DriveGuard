{
    "expo": {
        "name": "DriveGuard",
        "slug": "DriveGuard",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/images/icon.png",
        "scheme": "driveguard",
        "userInterfaceStyle": "automatic",
        "ios": {
            "bundleIdentifier": "com.adwaithananddev.DriveGuard"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/images/android-icon-foreground.png",
                "backgroundImage": "./assets/images/android-icon-background.png",
                "monochromeImage": "./assets/images/android-icon-monochrome.png"
            },
            "predictiveBackGestureEnabled": false,
            "package": "com.adwaithananddev.DriveGuard"
        },
        "web": {
            "output": "static",
            "favicon": "./assets/images/icon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#208AEF",
                    "image": "./assets/images/logo-glow.png",
                    "imageWidth": 76
                }
            ],
            "expo-video",
            "expo-image",
            "expo-status-bar",
            "expo-web-browser",
            "./modules/drive-cam/app.plugin.js"
        ],
        "experiments": {
            "typedRoutes": true,
            "reactCompiler": true
        },
        "extra": {
            "router": {},
            "eas": {
                "projectId": "426c7e49-5f42-49c6-b2c4-c9828922d2d1"
            }
        }
    }
}
